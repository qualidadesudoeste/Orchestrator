NODE_ENV=production
HOST=0.0.0.0
PORT=3000
TZ=America/Sao_Paulo
VITE_APP_ID=orchestrator-production

# Codifique caracteres especiais da senha ao montar a URL.
DATABASE_URL=mysql://orchestrator:SENHA_URL_ENCODED@mysql:3306/orchestrator
MYSQL_PASSWORD=GERE_UMA_SENHA_FORTE_DIFERENTE
MYSQL_ROOT_PASSWORD=GERE_OUTRA_SENHA_FORTE

JWT_SECRET=GERE_UM_SEGREDO_ALEATORIO_COM_64_CARACTERES
QA_AGENT_API_TOKEN=GERE_OUTRO_TOKEN_ALEATORIO_COM_64_CARACTERES
ORCHESTRATOR_PUBLIC_URL=https://qa.seudominio.com.br

BUILT_IN_FORGE_API_URL=https://api.openai.com
BUILT_IN_FORGE_API_KEY=

# Número de proxies confiáveis entre o cliente e o Node. Use 1 com um único proxy.
TRUST_PROXY=1
JSON_BODY_LIMIT=10mb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_API_MAX=600
RATE_LIMIT_LOGIN_MAX=10
SHUTDOWN_TIMEOUT_MS=10000

VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# Publicação local do container; mantenha 127.0.0.1 quando houver proxy reverso.
APP_BIND_ADDRESS=127.0.0.1
APP_PORT=3000
APP_VERSION=local
