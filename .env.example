# Aplicação
NODE_ENV=development
PORT=3000
VITE_APP_ID=orchestrator-local

# Banco MySQL
DATABASE_URL=mysql://orchestrator:troque_a_senha@localhost:3306/orchestrator

# Autenticação local — gere um valor aleatório longo para cada ambiente
JWT_SECRET=substitua_por_um_segredo_aleatorio_com_pelo_menos_32_caracteres

# IA — endpoint compatível com a API de chat completions da OpenAI
BUILT_IN_FORGE_API_URL=https://api.openai.com
BUILT_IN_FORGE_API_KEY=

# OAuth legado (opcional; a autenticação local é o fluxo atual)
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
VITE_OAUTH_PORTAL_URL=

# Integrações visuais opcionais
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
