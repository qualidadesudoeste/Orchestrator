# Aplicação
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
VITE_APP_ID=orchestrator-local

# Banco MySQL
DATABASE_URL=mysql://orchestrator:troque_a_senha@localhost:3306/orchestrator

# Autenticação local — gere um valor aleatório longo para cada ambiente
JWT_SECRET=substitua_por_um_segredo_aleatorio_com_pelo_menos_32_caracteres

# Integração n8n -> Orchestrator para geração automática de evidências DOCX
# Use exatamente o mesmo valor em automation/n8n/.env
QA_AGENT_API_TOKEN=substitua_por_um_token_aleatorio_com_pelo_menos_32_caracteres
ORCHESTRATOR_PUBLIC_URL=http://localhost:3000

# Operação HTTP. Em produção, confie apenas na quantidade real de proxies.
TRUST_PROXY=false
JSON_BODY_LIMIT=10mb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_API_MAX=600
RATE_LIMIT_LOGIN_MAX=10
SHUTDOWN_TIMEOUT_MS=10000

# IA — endpoint compatível com a API de chat completions da OpenAI
BUILT_IN_FORGE_API_URL=https://api.openai.com
BUILT_IN_FORGE_API_KEY=

# OAuth legado (opcional; a autenticação local é o fluxo atual)
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
VITE_OAUTH_PORTAL_URL=

# Integrações visuais opcionais
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
